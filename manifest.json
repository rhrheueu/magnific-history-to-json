{
  "manifest_version": 3,
  "name": "Freepik History to JSON",
  "version": "0.1.0",
  "description": "Export Freepik prompt history to JSON for reports.",
  "action": {
    "default_title": "Скачать историю Freepik",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "permissions": ["downloads", "activeTab", "scripting", "storage", "contextMenus"],
  "host_permissions": [
    "https://*.freepik.com/*",
    "https://freepik.com/*",
    "https://*.cdnpk.net/*"
  ]
}
